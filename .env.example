# -----------------------------
# MinIO / S3-compatible storage
# -----------------------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_minio_root

MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=lake

# Host access (local tools, Makefile, mc, curl)
MINIO_ENDPOINT=http://localhost:9100

# Docker internal network access (Spark / ClickHouse / services)
MINIO_ENDPOINT_DOCKER=http://minio:9000

# -----------------------------
# Nessie
# -----------------------------
NESSIE_ENDPOINT=http://nessie:19120/api/v2
NESSIE_REF=main

# -----------------------------
# ClickHouse
# -----------------------------
CLICKHOUSE_PASSWORD=change_me_clickhouse_password

# -----------------------------
# Superset
# -----------------------------
SUPERSET_DB_PASSWORD=change_me_superset_db_password
SUPERSET_SECRET_KEY=change_me_superset_secret_key
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_ADMIN_PASSWORD=change_me_superset_admin_password
