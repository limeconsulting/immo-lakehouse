#!/usr/bin/env python3
import argparse
import gzip
import hashlib
import os
import sys
import tempfile
from datetime import datetime
from urllib.request import urlopen, Request
from urllib.error import HTTPError, URLError

# Requires: pip install minio
from minio import Minio
from minio.error import S3Error

DVF_URL_TEMPLATE = "https://files.data.gouv.fr/geo-dvf/latest/csv/{year}/full.csv.gz"
# If this URL changes later, we’ll adapt; the rest of pipeline stays stable.

def sha256_file(path: str) -> str:
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def download(url: str, out_path: str) -> None:
    req = Request(url, headers={"User-Agent": "immo-lake/1.0"})
    with urlopen(req, timeout=60) as r, open(out_path, "wb") as f:
        while True:
            b = r.read(1024 * 1024)
            if not b:
                break
            f.write(b)

def filter_dep_from_gz_csv(src_gz: str, dep: str, out_gz: str) -> dict:
    """
    Keep only rows with Code departement == dep.
    DVF schema has 'Code departement' column in geo-dvf full.csv.
    We stream-decompress and re-compress to out_gz.
    """
    kept = 0
    total = 0
    header = None
    dep_idx = None

    with gzip.open(src_gz, "rt", encoding="utf-8", errors="replace") as fin:
        with gzip.open(out_gz, "wt", encoding="utf-8") as fout:
            header = fin.readline()
            if not header:
                raise RuntimeError("Empty DVF file.")
            fout.write(header)

            cols = [c.strip() for c in header.strip().split(",")]
            # Common column name in geo-dvf: "Code departement"
            #try:
            #    dep_idx = cols.index("Code departement")
            #except ValueError:
            #    raise RuntimeError(f"'Code departement' column not found. Columns: {cols[:20]}...")
            
            # DVF variants: geo-dvf (Title Case) vs data.gouv DVF exports (snake_case)
            candidates = ["code_departement", "Code departement", "Code departement"]

            dep_idx = None
            for name in candidates:
                if name in cols:
                    dep_idx = cols.index(name)
                    break
            if dep_idx is None:
                raise RuntimeError(
                    "Department column not found. Tried: "
                    + ", ".join(candidates)
                    + f". Columns: {cols[:30]}..."
                ) 
            for line in fin:
                total += 1
                parts = line.split(",")
                if len(parts) <= dep_idx:
                    continue
                if parts[dep_idx].strip().strip('"') == dep:
                    fout.write(line)
                    kept += 1

    return {"total_rows": total, "kept_rows": kept}

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--year", required=True, type=int)
    ap.add_argument("--dep", required=True, type=str)
    ap.add_argument("--minio-endpoint", required=True)
    ap.add_argument("--access-key", required=True)
    ap.add_argument("--secret-key", required=True)
    ap.add_argument("--bucket", required=True)
    args = ap.parse_args()

    year = args.year
    dep = args.dep
    ingest_date = datetime.utcnow().strftime("%Y-%m-%dT%H%M%SZ")

    url = DVF_URL_TEMPLATE.format(year=year)

    os.makedirs("/tmp/immo-lake", exist_ok=True)
    with tempfile.TemporaryDirectory(prefix="immo-lake-") as td:
        raw_path = os.path.join(td, f"dvf_full_{year}.csv.gz")
        dep_path = os.path.join(td, f"dvf_dep{dep}_{year}.csv.gz")

        print(f"Downloading DVF: {url}")
        download(url, raw_path)
        raw_sha = sha256_file(raw_path)
        print(f"Downloaded: {raw_path} sha256={raw_sha}")

        print(f"Filtering department={dep} ...")
        stats = filter_dep_from_gz_csv(raw_path, dep, dep_path)
        dep_sha = sha256_file(dep_path)
        print(f"Filtered rows kept={stats['kept_rows']} total_scanned={stats['total_rows']}")
        print(f"Output: {dep_path} sha256={dep_sha}")

        # Upload to MinIO
        mc = Minio(
            args.minio_endpoint.replace("http://", "").replace("https://", ""),
            access_key=args.access_key,
            secret_key=args.secret_key,
            secure=args.minio_endpoint.startswith("https://"),
        )

        key = f"raw/dvf/ingest={ingest_date}/year={year}/dep={dep}/dvf_dep{dep}_{year}.csv.gz"
        manifest_key = f"raw/dvf/ingest={ingest_date}/year={year}/dep={dep}/manifest.txt"

        try:
            # ensure bucket exists
            found = mc.bucket_exists(args.bucket)
            if not found:
                raise RuntimeError(f"Bucket '{args.bucket}' does not exist. Run: make mc-init")

            mc.fput_object(args.bucket, key, dep_path, content_type="application/gzip")
            manifest = (
                f"url={url}\n"
                f"year={year}\n"
                f"dep={dep}\n"
                f"raw_sha256={raw_sha}\n"
                f"dep_sha256={dep_sha}\n"
                f"total_rows_scanned={stats['total_rows']}\n"
                f"kept_rows={stats['kept_rows']}\n"
            )
            with open(os.path.join(td, "manifest.txt"), "w", encoding="utf-8") as f:
                f.write(manifest)
            mc.fput_object(args.bucket, manifest_key, os.path.join(td, "manifest.txt"), content_type="text/plain")
            print(f"Uploaded to s3://{args.bucket}/{key}")
            print(f"Uploaded manifest s3://{args.bucket}/{manifest_key}")
        except S3Error as e:
            print(f"MinIO error: {e}", file=sys.stderr)
            sys.exit(2)

if __name__ == "__main__":
    main()
