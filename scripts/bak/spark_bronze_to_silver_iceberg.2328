#!/usr/bin/env python3
import argparse

from pyspark.sql import SparkSession
from pyspark.sql.functions import col, lit

# Column candidates across dvf variants
CANDIDATES = {
    "date_mutation": ["date_mutation", "Date mutation"],
    "valeur_fonciere": ["valeur_fonciere", "Valeur fonciere", "Valeur foncière"],
    "surface_reelle_bati": ["surface_reelle_bati", "Surface reelle bati", "Surface reelle batie", "Surface réelle bati"],
    "code_commune": ["code_commune", "Code commune"],
    "type_local": ["type_local", "Type local"],
    "code_departement": ["code_departement", "Code departement", "Code département"],
}

def pick_col(df, names):
    cols = set(df.columns)
    for n in names:
        if n in cols:
            return col(n)
    return None

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--minio-endpoint", required=True)
    ap.add_argument("--access-key", required=True)
    ap.add_argument("--secret-key", required=True)
    ap.add_argument("--bucket", required=True)
    ap.add_argument("--nessie", required=True)
    ap.add_argument("--ref", required=True)
    ap.add_argument("--year", required=True, type=int)
    ap.add_argument("--dep", required=True)
    ap.add_argument("--ingest-id", required=False, default=None, help="If set, read only this ingest_id; else ingest=*")
    args = ap.parse_args()

    nessie_uri = args.nessie.rstrip("/")
    if not (nessie_uri.endswith("/api/v2") or nessie_uri.endswith("/api/v1")):
        nessie_uri = nessie_uri + "/api/v2"

    spark = (
        SparkSession.builder.appName("dvf-bronze-to-silver")
        .config("spark.sql.extensions", "org.apache.iceberg.spark.extensions.IcebergSparkSessionExtensions")
        .config("spark.sql.catalog.nessie", "org.apache.iceberg.spark.SparkCatalog")
        .config("spark.sql.catalog.nessie.catalog-impl", "org.apache.iceberg.nessie.NessieCatalog")
        .config("spark.sql.catalog.nessie.uri", nessie_uri)
        .config("spark.sql.catalog.nessie.ref", args.ref)
        .config("spark.sql.catalog.nessie.warehouse", f"s3a://{args.bucket}/warehouse/iceberg")
        .config("spark.hadoop.fs.s3a.endpoint", args.minio_endpoint)
        .config("spark.hadoop.fs.s3a.access.key", args.access_key)
        .config("spark.hadoop.fs.s3a.secret.key", args.secret_key)
        .config("spark.hadoop.fs.s3a.path.style.access", "true")
        .config("spark.hadoop.fs.s3a.connection.ssl.enabled", "false" if args.minio_endpoint.startswith("http://") else "true")
        .getOrCreate()
    )

    # Bronze path: prefer a fixed ingest-id when provided
    ingest_part = f"ingest={args.ingest_id}" if args.ingest_id else "ingest=*"
    bronze_glob = f"s3a://{args.bucket}/raw/dvf/{ingest_part}/year={args.year}/dep={args.dep}/*.csv.gz"
    print(f"Reading bronze from: {bronze_glob}")

    df = spark.read.option("header", True).csv(bronze_glob)

    # Resolve columns robustly
    c_date = pick_col(df, CANDIDATES["date_mutation"])
    c_vf = pick_col(df, CANDIDATES["valeur_fonciere"])
    c_surf = pick_col(df, CANDIDATES["surface_reelle_bati"])
    c_commune = pick_col(df, CANDIDATES["code_commune"])
    c_type = pick_col(df, CANDIDATES["type_local"])
    c_dep = pick_col(df, CANDIDATES["code_departement"])

    missing = []
    if c_date is None: missing.append("date_mutation")
    if c_vf is None: missing.append("valeur_fonciere")
    if c_surf is None: missing.append("surface_reelle_bati")
    if c_commune is None: missing.append("code_commune")
    if c_type is None: missing.append("type_local")
    if c_dep is None: missing.append("code_departement")
    if missing:
        raise RuntimeError(f"Missing required DVF columns: {missing}. Available columns sample: {df.columns[:40]}")

    # Normalize into a stable silver schema
    df2 = (
        df.withColumn("date_mutation", c_date.cast("date"))
          .withColumn("valeur_fonciere", c_vf.cast("double"))
          .withColumn("surface_reelle_bati", c_surf.cast("double"))
          .withColumn("code_commune", c_commune.cast("string"))
          .withColumn("type_local", c_type.cast("string"))
          .withColumn("dep", c_dep.cast("string"))
          .withColumn("annee", col("date_mutation").substr(1, 4).cast("int"))
          .withColumn("ingest_id", lit(args.ingest_id if args.ingest_id else "wildcard"))
    )

    # Create database / table
    spark.sql("CREATE DATABASE IF NOT EXISTS nessie.immo")

    # Add ingest_id column so you can trace loads
    spark.sql("""
      CREATE TABLE IF NOT EXISTS nessie.immo.dvf_silver (
        date_mutation date,
        valeur_fonciere double,
        code_commune string,
        type_local string,
        surface_reelle_bati double,
        dep string,
        annee int,
        ingest_id string
      )
      USING iceberg
      PARTITIONED BY (dep, annee)
    """)

    (
        df2.select(
            "date_mutation","valeur_fonciere","code_commune","type_local","surface_reelle_bati","dep","annee","ingest_id"
        )
        .where(col("dep") == args.dep)
        .where(col("annee") == args.year)
        .writeTo("nessie.immo.dvf_silver")
        .append()
    )

    print("OK: wrote to nessie.immo.dvf_silver")
    spark.stop()

if __name__ == "__main__":
    main()
